{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "sortImports": true,
  "sortPackageJson": true,
  "trailingComma": "all",
  "ignorePatterns": ["node_modules", "dist", "coverage", "packages/*/dist", "**/*.tsbuildinfo"]
}
