{
  "name": "split-like-vscode",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@worksplit/demo --ui stream",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "turbo run lint && oxlint -c oxlint.config.ts oxlint.config.ts --deny-warnings",
    "lint:fix": "oxlint -c oxlint.config.ts . --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck && tsc -p tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "tsdown": "^0.22.3",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.8.0"
}
