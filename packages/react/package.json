{
  "name": "@worksplit/react",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "dist/style.css",
    "src/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "build": "vite build && tsc -b tsconfig.build.json --force",
    "format:check": "oxfmt . --check",
    "lint": "oxlint -c ../../oxlint.config.ts . --deny-warnings",
    "test": "vitest run src --environment jsdom",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@worksplit/core": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  }
}
