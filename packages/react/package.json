{
  "name": "@worksplit/react",
  "version": "0.1.0",
  "files": [
    "dist",
    "src/index.ts",
    "src/split-view.tsx",
    "src/style.css",
    "src/workbench-model.ts",
    "src/workbench.tsx"
  ],
  "type": "module",
  "sideEffects": [
    "dist/style.css",
    "src/style.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json",
    "./style.css": "./src/style.css"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json",
      "./style.css": "./dist/style.css"
    }
  },
  "scripts": {
    "build": "tsdown",
    "format:check": "oxfmt . --check",
    "lint": "oxlint -c ../../oxlint.config.ts . --deny-warnings",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@worksplit/core": "workspace:*"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  }
}
