{
  "name": "@worksplit/core",
  "version": "0.1.0",
  "files": [
    "dist",
    "src/index.ts",
    "src/workbench.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "format:check": "oxfmt . --check",
    "lint": "oxlint -c ../../oxlint.config.ts . --deny-warnings",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
